{
  "name": "etape",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "prettier": "@etape/prettier-config",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css}\""
  },
  "devDependencies": {
    "@etape/prettier-config": "*",
    "prettier": "^3.9.6",
    "turbo": "^2"
  },
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=20"
  }
}
